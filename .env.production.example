ENVIRONMENT=production
DEBUG=false

JWT_SECRET_KEY=replace-this-with-a-64-character-random-production-secret
MONGODB_URI=mongodb://mongo:27017/sentinelxdr
REDIS_URL=redis://redis:6379/0
BACKEND_CORS_ORIGINS=https://sentinelxdr.example.com
VITE_API_BASE_URL=https://sentinelxdr.example.com
EVIDENCE_STORAGE_ROOT=/app/storage/evidence
EVIDENCE_MAX_UPLOAD_MB=25

# Keep disabled for internet-facing production deployments.
EXPOSE_API_DOCS=false

# Optional host port override for the root nginx reverse proxy.
NGINX_HTTP_PORT=80
