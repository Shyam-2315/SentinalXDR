APP_NAME=SentinelXDR API
APP_VERSION=0.1.0
ENVIRONMENT=local
DEBUG=false
API_V1_PREFIX=/api/v1

MONGODB_URI=mongodb://mongo:27017
MONGODB_DATABASE=sentinelxdr
MONGODB_PING_TIMEOUT_MS=1000

REDIS_URL=redis://redis:6379/0
REDIS_PING_TIMEOUT_SECONDS=1.0

JWT_SECRET_KEY=change-me-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AGENT_API_KEY_BYTES=32
EVENT_INGEST_BATCH_SIZE_LIMIT=100
